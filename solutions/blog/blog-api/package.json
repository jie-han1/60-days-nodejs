{
  "name": "blog-api",
  "version": "0.3.0",
  "description": "Blog API — Day 20 内存版 → Day 27 Prisma → Day 32-34 认证授权 → Day 35 安全防护 → Day 36 Redis 缓存 → Day 37 Redis 进阶（排行榜 + 分布式锁）→ Day 38 消息队列（BullMQ：异步邮件 / 重试 / 死信）→ Day 39 文件上传与存储（Multer + Sharp + S3/R2/MinIO）→ Day 40 安全加固 → Day 41 Docker 镜像 → Day 42 Docker Compose 编排（迁移 job + 就绪探针）",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test": "node --test --test-concurrency=1 -r ts-node/register -r ./test/setup.cjs test/*.test.ts",
    "test:unit": "node --test -r ts-node/register -r ./test/setup.cjs test/*.unit.test.ts",
    "test:e2e": "node --test --test-concurrency=1 -r ts-node/register -r ./test/setup.cjs test/*.e2e.test.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "pnpm": {
    "//": "pnpm 默认拦截依赖的构建脚本；放行 prisma 引擎下载，配合上面的 postinstall 让 pnpm install 后自动 prisma generate",
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.61.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "multer": "^1.4.4",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
