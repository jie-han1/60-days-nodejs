# ============================================================================
# blog-api 生产环境变量模板 —— Day 44
# ----------------------------------------------------------------------------
# 这份不是给 `pnpm start` 直接读的（生产里没有 .env 文件进容器——见下）。
# 它是【对照清单】：上线时要在云平台（Railway 服务的 Variables / Fly 的 fly secrets set）
# 把下面每一项填进去。`config.validation.ts` 会在启动时用 zod 校验——缺/错第一秒就崩。
#
# 和 .env.example（开发用）的关键区别：
#   - NODE_ENV=production：config 会因此【拒绝】示例 JWT secret（防占位值被带上线）。
#   - DATABASE_URL / REDIS_URL 指向【托管服务】（Supabase/Neon 的 PG、Upstash 的 Redis），
#     不再是 localhost。
#   - STORAGE_BACKEND=s3：生产用对象存储，不用容器内的 /app/uploads（多实例 / 重启会丢）。
#   - CORS / OAuth 回调换成你的真实 https 域名。
#
# 平台上这些是【加密变量】，绝不进 Git。本文件只列结构 + 占位，不含任何真密钥。
# ============================================================================

NODE_ENV=production
# PORT 由平台注入：Railway 会把 PORT 设成它代理的端口；Fly 用 fly.toml 的 internal_port。
# 应用读 PORT（config.validation.ts），所以这里给不给都行，平台给的优先。
PORT=3000

# 前端域名（多个用逗号分隔）。上线后填你的真实域名，http 已经不行了——见下方 HTTPS 说明。
CORS_ORIGIN=https://your-blog.example.com

# ── 托管 PostgreSQL（Supabase / Neon / Railway 自带 PG）─────────────────────
# 用【直连 URL】（非连接池）：这样迁移和运行时用同一条串、最省事，正确性没问题。
# Supabase：Project Settings → Database → Connection string → 【Session pooler / Direct】
# Neon：Dashboard → Connection Details → 选 "Pooled connection" 之外的 direct 连接
DATABASE_URL=postgresql://USER:PASSWORD@db.host.supabase.co:5432/postgres?schema=blog_api

# 进阶（流量大了再上）：托管 PG 一般用 PgBouncer 做【连接池】（端口 6543 / pooler 域名）。
# Prisma 走池子要两件事，否则报 "prepared statement ... does not exist"：
#   1. url 指向池子、带参数：?pgbouncer=true&connection_limit=1
#   2. 给 schema 加 directUrl，迁移走【直连】（migrate 不能走事务模式的池子）：
#        datasource db { url = env("DATABASE_URL") directUrl = env("DIRECT_DATABASE_URL") }
# 我们这一版保持简单（直连一条串），把上面这步留到需要扛并发连接数时再做。详见 day-44 README。
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@db.host.supabase.co:5432/postgres?schema=blog_api

# ── 托管 Redis（Upstash 等）─────────────────────────────────────────────────
# Upstash 给的是 rediss://（TLS）。config 接受 rediss://（见 config.validation.ts 的 refine）。
# 缓存 / 队列都是【可选降级层】——Redis 临时不通，API 退回直连 DB，不会 500。
REDIS_URL=rediss://default:PASSWORD@us1-xxx.upstash.io:6379

# ── JWT：生产必须换成强随机串 ───────────────────────────────────────────────
# NODE_ENV=production 时，config 会拒绝 .env.example 里那个 dev-only 示例值。
# 生成：openssl rand -base64 32  （≥32 字符；HS256 建议 ≥256-bit）
JWT_ACCESS_SECRET=替换成-openssl-rand-base64-32-的强随机串
JWT_ACCESS_TTL=900
REFRESH_TTL_DAYS=7

# ── 文件存储：生产走 S3 兼容（这里以 Cloudflare R2 为例）────────────────────
# 容器内的 /app/uploads 不持久（重启 / 多实例各写各的）。R2 / AWS S3 / MinIO 同一套 API。
STORAGE_BACKEND=s3
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # AWS S3 留空；MinIO 用 http://host:9000
S3_REGION=auto                                            # R2=auto；AWS 用真实 region
S3_BUCKET=your-blog-media
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_FORCE_PATH_STYLE=false                                 # R2/AWS=false；MinIO=true
# 封面图对外的公开访问前缀（R2 开了公开访问的域名 / 自定义域）。不填则按 endpoint+bucket 拼。
S3_PUBLIC_BASE_URL=https://media.your-blog.example.com
UPLOAD_MAX_BYTES=5242880
COVER_MAX_WIDTH=1600
COVER_FORMAT=webp

# ── GitHub OAuth（可选）：回调 URL 改成生产域名 ─────────────────────────────
# 不填 GITHUB_CLIENT_ID/SECRET 就禁用 GitHub 登录，不影响启动。
# 记得去 GitHub OAuth App 把 Authorization callback URL 也改成下面的生产地址。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-blog.example.com/auth/github/callback
