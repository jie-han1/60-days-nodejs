# 复制为 .env 后按需修改。`.env` 不会被提交。
NODE_ENV=development
PORT=3000

# 多个域名用逗号分隔
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# 分页默认值
PAGE_LIMIT=20

# Day 27：数据库连接串。复用 blog-db 起的 PG 实例，但用独立 schema=blog_api，
# 和 blog-db 的 public schema（7 张表那套）隔离，互不污染。
DATABASE_URL=postgresql://blog:blog_dev_pwd@localhost:5432/blog?schema=blog_api

# Day 32：JWT。JWT_ACCESS_SECRET 必填——生产请用强随机串（如 openssl rand -base64 32），别用下面这个示例值。
JWT_ACCESS_SECRET=dev-only-access-secret-change-me-please
JWT_ACCESS_TTL=900        # access token 存活秒数（默认 15 分钟）
REFRESH_TTL_DAYS=7        # refresh token 存活天数

# Day 34：GitHub OAuth（可选）。不填这两个就禁用 GitHub 登录，不影响启动。
# 去 GitHub → Settings → Developer settings → OAuth Apps 新建一个，
# Authorization callback URL 填下面的 GITHUB_CALLBACK_URL。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Day 35：限流（每 IP 在窗口内最多多少请求）。ttl 单位是秒。
# 这是"总闸"默认值，登录 / 注册在控制器里另有更紧的配额；这里给宽点，不挡正常用户。
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=1000

# Day 40：安全加固。账号锁定（防密码爆破，按【账号】计数，和上面按【IP】的限流正交）
# + 请求体上限（防大 payload DoS）。都有默认值，可不填。
LOGIN_MAX_ATTEMPTS=5       # 同一账号连续登录失败几次后锁定（默认 5）
LOGIN_LOCK_MINUTES=15      # 锁定持续分钟数：到点自动解锁，无需人工介入，也不会永久误锁
HTTP_BODY_LIMIT_KB=100     # JSON 请求体硬上限（KB）：超大 payload 在解析阶段就被拒成 413

# Day 36：Redis 缓存。和数据库的「必填」相反——Redis 是可选的真相外层：
# 连接串默认指向 blog-db 起的本地容器（见 solutions/blog/blog-db/docker-compose.yml 的 redis 服务）；
# 连不上也不会让 API 挂掉，最坏只是缓存不生效、请求直连数据库。
REDIS_URL=redis://localhost:6379
POST_CACHE_TTL=300    # 单篇缓存秒数（默认 5 分钟）：读多写少，给长点
LIST_CACHE_TTL=60     # 列表缓存秒数（默认 1 分钟）：列表变化频繁，给短点
# Day 37：缓存进阶三参数（都有默认值，可不填）。
CACHE_TTL_JITTER=60       # 雪崩对策：TTL 随机抖动上限（秒），让 key 过期时刻错开
NEGATIVE_CACHE_TTL=30     # 穿透对策：负缓存（不存在的 id）存活秒数，故意短
LOCK_TTL=3                # 击穿对策：分布式锁存活秒数（≥ 最慢一次缓存重建）

# Day 38：消息队列（BullMQ，复用上面同一个 Redis）。都有默认值，可不填。
# 队列是可选的异步层：连不上只影响「邮件异步发送」，不影响注册 / 发帖等主流程。
MAIL_ATTEMPTS=3           # 单个任务最多尝试次数（含首次）：瞬时故障自动重试，重试耗尽进死信
MAIL_BACKOFF_MS=1000      # 指数退避基准（毫秒）：第 n 次重试约等 base×2^(n-1)，避免一上来就狂轰
MAIL_CONCURRENCY=4        # 单 worker 进程并发处理数（发信是 IO 密集，并发能拉吞吐；过高会压垮下游 SMTP）
MAIL_SENT_TTL=86400       # 幂等标记「这封已发过」存活秒数（默认 1 天，覆盖最坏重试链）

# Day 39：文件上传与存储。默认本地磁盘——零配置可用（上传落到 ./uploads，由 express static 服务）。
# 改 STORAGE_BACKEND=s3 才走 S3 兼容对象存储（AWS / Cloudflare R2 / MinIO 同一套 API）。
# 注意它和 Redis 的降级哲学相反：选 s3 是运营决定，配错（缺 S3_BUCKET）应启动即崩，
# 而不是悄悄降级——别让用户传完图才发现没地方存。
STORAGE_BACKEND=local            # local（默认）| s3
STORAGE_LOCAL_DIR=uploads        # local：写入根目录（相对 cwd），默认 ./uploads
STORAGE_PUBLIC_PREFIX=/uploads   # local：对外 URL 前缀，需和 main.ts 挂载的 prefix 一致
UPLOAD_MAX_BYTES=5242880         # 单文件硬上限（5 MiB）：超了 multer 在缓冲阶段就中断
COVER_MAX_WIDTH=1600             # 封面归一化最大宽度（不放大小图），省带宽
COVER_FORMAT=webp                # 归一化目标格式：webp（默认）/ jpeg / png

# S3 兼容（仅 STORAGE_BACKEND=s3 时需要）。AWS / Cloudflare R2 / MinIO 各自填法：
#   AWS S3： endpoint 留空，region=ap-east-1，forcePathStyle=false
#   R2：    endpoint=https://<account>.r2.cloudflarestorage.com，region=auto，forcePathStyle=false
#   MinIO： endpoint=http://localhost:9000，region=任意，forcePathStyle=true
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
# 公开访问前缀（CDN / R2 公开域名 / 自定义域）。不填则按 endpoint+bucket 拼路径风格 URL。
S3_PUBLIC_BASE_URL=

# Day 45：可观测性——结构化日志（pino）+ 错误上报（Sentry）。都是「可选观测层」：
# 日志级别写错会启动即崩；Sentry 没配 DSN 时上报静默 no-op，连不上也不影响业务。
LOG_LEVEL=info          # fatal/error/warn/info/debug/trace/silent；生产通常 info，排查时临时 debug
SENTRY_DSN=             # 不填 = 不启用。去 sentry.io 建项目拿 DSN 填进来才上报错误
SENTRY_ENVIRONMENT=     # 不填回退 NODE_ENV（如 production/staging），便于在 Sentry 按环境分组
SENTRY_RELEASE=         # 可选：版本号（如 git sha），填了才能在 Sentry 按「引入版本」聚合错误
SENTRY_TRACES_SAMPLE_RATE=0  # 性能采样率 0~1；默认 0 关闭（trace 每请求都采样，开销大，按需开）
